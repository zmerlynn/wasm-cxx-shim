@PACKAGE_INIT@

# wasm-cxx-shim package config.
#
# Usage:
#   find_package(wasm-cxx-shim REQUIRED COMPONENTS libc libm libcxx)
#   target_link_libraries(my-target PRIVATE
#       wasm-cxx-shim::libc
#       wasm-cxx-shim::libm
#       wasm-cxx-shim::libcxx)
#
# Components are independent. Pull only what you need; if your project
# already has a libm (e.g., from Rust's `libm` crate FFI-exported), skip
# our libm and the libc/libcxx halves still work.

# Locate per-component target files. Each is generated independently by
# the matching install(EXPORT …) — so a build that only enables one
# component still produces a usable package.
set(_wasm_cxx_shim_supported_components libc libm libcxx)

foreach(_comp IN LISTS wasm-cxx-shim_FIND_COMPONENTS)
    list(FIND _wasm_cxx_shim_supported_components "${_comp}" _idx)
    if(_idx EQUAL -1)
        set(wasm-cxx-shim_${_comp}_FOUND FALSE)
        if(wasm-cxx-shim_FIND_REQUIRED_${_comp})
            set(wasm-cxx-shim_FOUND FALSE)
            set(wasm-cxx-shim_NOT_FOUND_MESSAGE
                "Unknown component '${_comp}'. Supported: ${_wasm_cxx_shim_supported_components}")
            return()
        endif()
        continue()
    endif()

    set(_targets_file "${CMAKE_CURRENT_LIST_DIR}/wasm-cxx-shim-${_comp}-targets.cmake")
    if(EXISTS "${_targets_file}")
        include("${_targets_file}")
        set(wasm-cxx-shim_${_comp}_FOUND TRUE)
    else()
        set(wasm-cxx-shim_${_comp}_FOUND FALSE)
        if(wasm-cxx-shim_FIND_REQUIRED_${_comp})
            set(wasm-cxx-shim_FOUND FALSE)
            set(wasm-cxx-shim_NOT_FOUND_MESSAGE
                "Component '${_comp}' was not built/installed (missing ${_targets_file})")
            return()
        endif()
    endif()
endforeach()

# If no COMPONENTS were specified, load whichever are present. This
# matches the behavior consumers expect from a `find_package` without
# explicit COMPONENTS.
if(NOT wasm-cxx-shim_FIND_COMPONENTS)
    foreach(_comp IN LISTS _wasm_cxx_shim_supported_components)
        set(_targets_file "${CMAKE_CURRENT_LIST_DIR}/wasm-cxx-shim-${_comp}-targets.cmake")
        if(EXISTS "${_targets_file}")
            include("${_targets_file}")
            set(wasm-cxx-shim_${_comp}_FOUND TRUE)
        endif()
    endforeach()
endif()

check_required_components(wasm-cxx-shim)
